"""Estimate daily driving mileage from calendar events and known route data.

The core logic answers: did you go directly to the next event, or return to your
starting address first?

Rule used between consecutive events:
- Compute gap_minutes = next.start - current.end
- Compute direct_drive_minutes = drive time from current.location to next.location
- If gap_minutes - direct_drive_minutes > idle_threshold_minutes, assume you went
  back to the starting address before the next event.
- Otherwise assume you went directly.
"""

from __future__ import annotations

import argparse
import datetime as dt
import json
from dataclasses import dataclass
from pathlib import Path


class CalendarParseError(ValueError):
    """Raised when an .ics file cannot be parsed."""


class RouteLookupError(KeyError):
    """Raised when route information between two addresses is missing."""


@dataclass(frozen=True)
class RouteInfo:
    miles: float
    minutes: int


@dataclass(frozen=True)
class CalendarEvent:
    start: dt.datetime
    end: dt.datetime
    location: str
    summary: str = ""


def unfold_ical_lines(raw_text: str) -> list[str]:
    lines = raw_text.splitlines()
    unfolded: list[str] = []
    for line in lines:
        if line.startswith((" ", "\t")) and unfolded:
            unfolded[-1] += line[1:]
        else:
            unfolded.append(line)
    return unfolded


def _parse_ics_datetime(value: str) -> dt.datetime:
    cleaned = value.strip()
    if cleaned.endswith("Z"):
        cleaned = cleaned[:-1]

    if "T" in cleaned:
        return dt.datetime.strptime(cleaned, "%Y%m%dT%H%M%S")

    # VALUE=DATE format (all-day event): interpret as midnight local.
    return dt.datetime.strptime(cleaned, "%Y%m%d")


def events_for_date_from_ics(ics_text: str, target_date: dt.date) -> list[CalendarEvent]:
    lines = unfold_ical_lines(ics_text)
    events: list[CalendarEvent] = []

    in_event = False
    start: dt.datetime | None = None
    end: dt.datetime | None = None
    location = ""
    summary = ""

    for line in lines:
        if line == "BEGIN:VEVENT":
            in_event = True
            start = None
            end = None
            location = ""
            summary = ""
            continue

        if line == "END:VEVENT":
            if in_event and start and start.date() == target_date and location:
                if end is None:
                    end = start
                events.append(CalendarEvent(start=start, end=end, location=location, summary=summary))
            in_event = False
            continue

        if not in_event or ":" not in line:
            continue

        key, value = line.split(":", 1)
        base_key = key.split(";", 1)[0]

        if base_key == "DTSTART":
            try:
                start = _parse_ics_datetime(value)
            except ValueError as exc:
                raise CalendarParseError(f"Unsupported DTSTART format: {value}") from exc
        elif base_key == "DTEND":
            try:
                end = _parse_ics_datetime(value)
            except ValueError as exc:
                raise CalendarParseError(f"Unsupported DTEND format: {value}") from exc
        elif base_key == "LOCATION":
            location = value.strip()
        elif base_key == "SUMMARY":
            summary = value.strip()

    return sorted(events, key=lambda e: e.start)


def _route_key(a: str, b: str) -> tuple[str, str]:
    return tuple(sorted((a.strip().lower(), b.strip().lower())))


def lookup_route(routes: dict[tuple[str, str], RouteInfo], a: str, b: str) -> RouteInfo:
    key = _route_key(a, b)
    if key not in routes:
        raise RouteLookupError(f"Missing route data for '"'"'{a}'"'"' <-> '"'"'{b}'"'"'")
    return routes[key]


def estimate_daily_miles(
    start_address: str,
    events: list[CalendarEvent],
    routes: dict[tuple[str, str], RouteInfo],
    idle_threshold_minutes: int = 60,
) -> float:
    if not events:
        return 0.0

    total = 0.0

    # Home -> first event
    total += lookup_route(routes, start_address, events[0].location).miles

    for current, nxt in zip(events, events[1:]):
        gap_minutes = int((nxt.start - current.end).total_seconds() // 60)
        direct = lookup_route(routes, current.location, nxt.location)
        idle_if_direct = gap_minutes - direct.minutes

        if idle_if_direct > idle_threshold_minutes:
            total += lookup_route(routes, current.location, start_address).miles
            total += lookup_route(routes, start_address, nxt.location).miles
        else:
            total += direct.miles

    # Last event -> home
    total += lookup_route(routes, events[-1].location, start_address).miles

    return round(total, 2)


def _load_routes(path: Path) -> dict[tuple[str, str], RouteInfo]:
    data = json.loads(path.read_text(encoding="utf-8"))
    routes: dict[tuple[str, str], RouteInfo] = {}

    for item in data:
        a = item["from"]
        b = item["to"]
        routes[_route_key(a, b)] = RouteInfo(miles=float(item["miles"]), minutes=int(item["minutes"]))

    return routes


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Estimate daily driving mileage from calendar events.")
    parser.add_argument("calendar_file", type=Path, help="Path to iCalendar (.ics) file")
    parser.add_argument("routes_file", type=Path, help="JSON file containing route miles and minutes")
    parser.add_argument("date", help="Target date (YYYY-MM-DD)")
    parser.add_argument("start_address", help="Home/base address")
    parser.add_argument("--idle-threshold-minutes", type=int, default=60)
    return parser.parse_args()


def main() -> None:
    args = parse_args()
    target_date = dt.date.fromisoformat(args.date)

    ics_text = args.calendar_file.read_text(encoding="utf-8")
    events = events_for_date_from_ics(ics_text, target_date)
    routes = _load_routes(args.routes_file)

    miles = estimate_daily_miles(
        start_address=args.start_address,
        events=events,
        routes=routes,
        idle_threshold_minutes=args.idle_threshold_minutes,
    )
    print(f"{target_date.isoformat()}: {miles:.2f} miles")


if __name__ == "__main__":
    main()
