"""Calculate daily mileage totals from an iCalendar (.ics) file.

This tool looks for mileage values in event SUMMARY and DESCRIPTION fields,
then totals all values for a requested day.

Supported mileage patterns include examples like:
- "Run 5 mi"
- "Bike 12.4 miles"
- "Distance: 10km" (converted to miles)
"""

from __future__ import annotations

import argparse
import datetime as dt
import re
from pathlib import Path

MILES_PATTERN = re.compile(r"(?P<value>\d+(?:\.\d+)?)\s*(?P<unit>mi|mile|miles|km|kilometer|kilometers)\b", re.IGNORECASE)


class CalendarParseError(ValueError):
    """Raised when an .ics file cannot be parsed."""


def unfold_ical_lines(raw_text: str) -> list[str]:
    """Unfold folded iCalendar lines per RFC 5545.

    Continuation lines begin with a single space or tab.
    """
    lines = raw_text.splitlines()
    unfolded: list[str] = []
    for line in lines:
        if line.startswith((" ", "\t")) and unfolded:
            unfolded[-1] += line[1:]
        else:
            unfolded.append(line)
    return unfolded


def parse_event_date(value: str) -> dt.date:
    """Parse DTSTART date values in common iCalendar formats."""
    cleaned = value.strip()
    if "T" in cleaned:
        # Handle forms like 20260222T070000Z or 20260222T070000
        date_part = cleaned.split("T", 1)[0]
        return dt.datetime.strptime(date_part, "%Y%m%d").date()
    return dt.datetime.strptime(cleaned, "%Y%m%d").date()


def extract_miles_from_text(text: str) -> float:
    """Return total miles found in a string."""
    total = 0.0
    for match in MILES_PATTERN.finditer(text):
        value = float(match.group("value"))
        unit = match.group("unit").lower()
        if unit in {"km", "kilometer", "kilometers"}:
            value *= 0.621371
        total += value
    return total


def daily_miles_from_ics(ics_text: str, target_date: dt.date) -> float:
    """Sum mileage values for events on ``target_date`` from iCalendar text."""
    lines = unfold_ical_lines(ics_text)

    in_event = False
    event_date: dt.date | None = None
    event_text_parts: list[str] = []
    total = 0.0

    for line in lines:
        if line == "BEGIN:VEVENT":
            in_event = True
            event_date = None
            event_text_parts = []
            continue

        if line == "END:VEVENT":
            if in_event and event_date == target_date:
                total += extract_miles_from_text("\n".join(event_text_parts))
            in_event = False
            continue

        if not in_event or ":" not in line:
            continue

        key, value = line.split(":", 1)
        base_key = key.split(";", 1)[0]

        if base_key == "DTSTART":
            try:
                event_date = parse_event_date(value)
            except ValueError as exc:
                raise CalendarParseError(f"Unsupported DTSTART format: {value}") from exc
        elif base_key in {"SUMMARY", "DESCRIPTION"}:
            event_text_parts.append(value)

    return round(total, 2)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Calculate mileage done on a specific day from an .ics calendar file.")
    parser.add_argument("calendar_file", type=Path, help="Path to an iCalendar (.ics) file")
    parser.add_argument("date", help="Date to total miles for (YYYY-MM-DD)")
    return parser.parse_args()


def main() -> None:
    args = parse_args()
    target_date = dt.date.fromisoformat(args.date)
    ics_text = args.calendar_file.read_text(encoding="utf-8")
    miles = daily_miles_from_ics(ics_text, target_date)
    print(f"{target_date.isoformat()}: {miles:.2f} miles")


if __name__ == "__main__":
    main()
